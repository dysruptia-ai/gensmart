{
  "name": "@gensmart/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate --database-url-var=DATABASE_URL --migration-file-language=sql --migrations-dir=src/db/migrations up",
    "migrate:down": "node-pg-migrate --database-url-var=DATABASE_URL --migration-file-language=sql --migrations-dir=src/db/migrations down",
    "seed": "tsx src/db/seeds/index.ts",
    "seed:test-users": "tsx src/db/seeds/test-users.seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@gensmart/shared": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "mammoth": "^1.11.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-pg-migrate": "^7.0.0",
    "nodemailer": "^6.9.0",
    "openai": "^6.25.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.0",
    "qrcode": "^1.5.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/compression": "^1.7.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/multer": "^1.4.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.0.0",
    "@types/qrcode": "^1.5.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
